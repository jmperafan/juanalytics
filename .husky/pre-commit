#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Only type-check when code files are staged; content/doc edits commit instantly.
if git diff --cached --name-only | grep -qE '\.(ts|astro|mjs)$'; then
  echo "Code changes staged - running astro check..."
  npx astro check || {
    echo "TypeScript check failed!"
    exit 1
  }
fi
