---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentFilter from '../components/ContentFilter.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { formatDate, byDateDesc } from '../utils/format';

const books = (await getCollection('books')).sort(byDateDesc);
const allTags = books.flatMap(b => b.data.tags);
---

<BaseLayout title="Books | juanalytics">
  <section class="content-section">
    <div class="container">
      <div class="content-header">
        <h1>Books</h1>
      </div>
      {books.length === 0 ? (
        <p class="empty-state">No books yet. Check back soon!</p>
      ) : (
        <div class="content-with-sidebar">
          {allTags.length > 0 && (
            <ContentFilter
              tags={allTags}
              gridId="books-grid"
              cardClass="book-card"
            />
          )}
          <div id="books-grid" class="content-grid">
            {books.map((book) => (
              <a
                href={book.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="card content-card book-card"
                data-tags={JSON.stringify(book.data.tags)}
              >
                {book.data.thumbnail && !book.data.thumbnail.includes('placehold.co') ? (
                  <div class="book-cover">
                    <img src={book.data.thumbnail} alt={book.data.title} class="book-cover-image" />
                  </div>
                ) : book.data.thumbnail ? (
                  <div class="book-cover">
                    <p class="book-cover-placeholder-title">{book.data.title.split(' ').slice(4).join(' ')}</p>
                  </div>
                ) : (
                  <div class="card-image-placeholder book-icon-placeholder">
                    <Icon name="book" size={64} />
                  </div>
                )}
                <div class="card-content">
                  <h3 class="card-title">{book.data.title}</h3>
                  {book.data.publisher && (
                    <p class="card-meta book-publisher">{book.data.publisher}</p>
                  )}
                  <p class="card-meta">
                    Published: {formatDate(book.data.date)}
                  </p>
                  <p class="card-description">{book.data.description}</p>
                  {book.data.tags.length > 0 && (
                    <div class="card-tags">
                      {book.data.tags.map((tag) => (
                        <span class="tag content-tag" data-tag={tag}>{tag}</span>
                      ))}
                    </div>
                  )}
                  <div class="book-cta">
                    <span class="button book-cta-button">{book.data.buttonText} →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .book-cover {
    width: 100%;
    aspect-ratio: 7/8;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-cover-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .book-cover-placeholder-title {
    font-size: 2rem;
    font-weight: 600;
    text-align: center;
    color: var(--color-text-light);
    padding: 2rem;
    line-height: 1.3;
  }

  .book-icon-placeholder {
    height: 400px;
    overflow: hidden;
  }

  .book-publisher {
    color: var(--color-primary);
    font-weight: 600;
  }

  .book-cta {
    margin-top: auto;
  }

  .book-cta-button {
    display: inline-block;
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
  }
</style>
