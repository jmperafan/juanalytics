---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { buildUrl } from '../utils/urlHelper';
import { readContentYAML } from '../utils/yamlParser';
import { coordMap } from '../data/locations';

const { talks } = await readContentYAML();

const talkMarkers = talks
  .filter(t => t.location && t.location !== 'Virtual' && coordMap[t.location])
  .map(t => ({
    coords: coordMap[t.location!],
    title: t.title,
    event: t.event ?? '',
    location: t.location!,
  }));

// Deduplicate by location; keep count for popup
const seenLocations = new Set<string>();
const dedupedTalkMarkers = talkMarkers.filter(m => {
  if (seenLocations.has(m.location)) return false;
  seenLocations.add(m.location);
  return true;
});

const talkCountByLocation = talkMarkers.reduce<Record<string, number>>((acc, m) => {
  acc[m.location] = (acc[m.location] ?? 0) + 1;
  return acc;
}, {});

const talkMarkersWithCount = dedupedTalkMarkers.map(m => ({
  ...m,
  count: talkCountByLocation[m.location],
}));

const talksByLocation = talks
  .filter(t => t.location && t.location !== 'Virtual' && coordMap[t.location])
  .reduce<Record<string, Array<{title: string, event: string, year: string, url: string}>>>((acc, t) => {
    if (!acc[t.location!]) acc[t.location!] = [];
    acc[t.location!].push({
      title: t.title,
      event: t.event ?? '',
      year: t.date instanceof Date ? String(t.date.getFullYear()) : String(t.date).slice(0, 4),
      url: t.url ?? '',
    });
    return acc;
  }, {});
---

