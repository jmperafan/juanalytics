---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { geoMercator, geoPath, geoCentroid } from 'd3-geo';
import { feature } from 'topojson-client';
import { createRequire } from 'node:module';
import { coordMap } from '../data/locations';
import profilePhoto from '../assets/profile_photo.webp';

const talks = (await getCollection('talks')).map(t => t.data);

const locatedTalks = talks.filter(
  (t): t is typeof t & { location: string } =>
    !!t.location && t.location !== 'Virtual' && !!coordMap[t.location]
);

const talkMarkers = [...new Set(locatedTalks.map(t => t.location))].map(location => ({
  coords: coordMap[location]!,
  location,
}));

const talksByLocation = locatedTalks.reduce<
  Record<string, Array<{ title: string; event: string; year: string; url: string }>>
>((acc, t) => {
  (acc[t.location] ??= []).push({
    title: t.title,
    event: t.event,
    year: String(t.date.getFullYear()),
    url: t.url ?? '',
  });
  return acc;
}, {});

// ── Build-time map rendering (replaces the old runtime D3 + CDN setup) ──
const require = createRequire(import.meta.url);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const world: any = require('world-atlas/countries-50m.json');
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const allFeatures: any[] = (feature(world, world.objects.countries) as any).features;

// Bounding boxes to strip far-flung islands/territories from silhouettes
const geoBounds: Record<number, [[number, number], [number, number]]> = {
  528: [[3, 50], [8, 54]],
  826: [[-9, 49], [2, 58.8]],
  840: [[-130, 20], [-60, 55]],
  250: [[-5, 42], [8, 51]],
};

// eslint-disable-next-line @typescript-eslint/no-explicit-any
function filterToContinental(f: any, bbox: [[number, number], [number, number]]): any {
  const geom = f.geometry;
  const inBbox = (ring: number[][]) => {
    let sx = 0, sy = 0;
    for (const [x, y] of ring) { sx += x; sy += y; }
    const cx = sx / ring.length, cy = sy / ring.length;
    return cx >= bbox[0][0] && cx <= bbox[1][0] && cy >= bbox[0][1] && cy <= bbox[1][1];
  };
  if (geom.type === 'Polygon') return inBbox(geom.coordinates[0]) ? f : null;
  if (geom.type === 'MultiPolygon') {
    const polys = geom.coordinates.filter((p: number[][][]) => inBbox(p[0]));
    if (!polys.length) return null;
    return { type: 'Feature', geometry: { type: 'MultiPolygon', coordinates: polys } };
  }
  return f;
}

// ── Country silhouettes (lived) ──
const COUNTRY_W = 100, COUNTRY_H = 80, COUNTRY_PAD = 6;
const countryIds = { colombia: 170, uk: 826, netherlands: 528, usa: 840 };

const countryPaths = Object.fromEntries(
  Object.entries(countryIds).map(([name, id]) => {
    const found = allFeatures.find(f => +f.id === id);
    const renderFeature = found && geoBounds[id] ? filterToContinental(found, geoBounds[id]) : found;
    if (!renderFeature) return [name, null];
    const projection = geoMercator().fitExtent(
      [[COUNTRY_PAD, COUNTRY_PAD], [COUNTRY_W - COUNTRY_PAD, COUNTRY_H - COUNTRY_PAD]],
      renderFeature
    );
    return [name, geoPath(projection)(renderFeature)];
  })
) as Record<keyof typeof countryIds, string | null>;

// ── Continent panels (spoken) with talk location dots ──
const PANEL_W = 240, PANEL_H = 220, PANEL_PAD = 8;
const continentDefs = [
  { id: 'northamerica', label: 'USA', bbox: [-125, 24, -66, 50] as const, includeIds: [] as number[] },
  { id: 'europe', label: 'Europe', bbox: [-5, 35, 22, 57] as const, includeIds: [250] },
  { id: 'southamerica', label: 'South America', bbox: [-82, -56, -33, 14] as const, includeIds: [] as number[] },
];

const continentPanels = continentDefs.map(cont => {
  const features = allFeatures
    .filter(f => {
      if (cont.includeIds.includes(+f.id)) return true;
      try {
        const c = geoCentroid(f);
        return c[0] >= cont.bbox[0] && c[0] <= cont.bbox[2] &&
               c[1] >= cont.bbox[1] && c[1] <= cont.bbox[3];
      } catch {
        return false;
      }
    })
    .map(f => (geoBounds[+f.id] ? filterToContinental(f, geoBounds[+f.id]!) : f))
    .filter(Boolean);

  const collection = { type: 'FeatureCollection' as const, features };
  const projection = geoMercator().fitExtent(
    [[PANEL_PAD, PANEL_PAD], [PANEL_W - PANEL_PAD, PANEL_H - PANEL_PAD]],
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    collection as any
  );
  const pathGen = geoPath(projection);

  const dots = talkMarkers
    .filter(m => {
      const [lat, lon] = m.coords;
      return lon >= cont.bbox[0] && lon <= cont.bbox[2] && lat >= cont.bbox[1] && lat <= cont.bbox[3];
    })
    .map(m => {
      const pt = projection([m.coords[1], m.coords[0]]);
      return pt ? { x: pt[0], y: pt[1], location: m.location } : null;
    })
    .filter((d): d is NonNullable<typeof d> => d !== null);

  return {
    ...cont,
    paths: features.map(f => pathGen(f)).filter(Boolean) as string[],
    dots,
  };
});
---

<BaseLayout title="About | juanalytics">
  <section class="content-section">
    <div class="container">

      <!-- Intro -->
      <div class="about-intro">
        <div class="about-intro-text">
          <h1>About Me</h1>
          <p>
            I'm an Analytics Engineer born and raised in Cali, Colombia. But I lived in the Netherlands
            for most of my adult life. In 2026, my family and I relocated to Connecticut, US.
          </p>
          <p>
            I have a decade of experience working with data, mostly as an implementation consultant.
            Thanks to my clients I have been involved in most of the analytics lifecycle, from defining
            objectives and architecture to data modeling and reporting.
          </p>
          <p>
            Besides consultancy, teaching and community building are a core part of what I do.
            I've written a book, run meetups, built courses, and spoken at conferences around the world.
            The common thread: making analytics engineering more accessible to everyone working with data.
          </p>
        </div>
        <div class="about-intro-photo">
          <Image
            src={profilePhoto}
            alt="Juan Manuel Perafan"
            class="about-photo"
            width={315}
            height={315}
          />
        </div>
      </div>

      <div class="blog-post-content">

        <!-- Section 1: Now -->
        <h2>What I'm Up To</h2>
        <div class="now-grid">
          <div class="now-card">
            <div class="now-card-icon">&#x1F4DA;</div>
            <div>
              <strong>Teaching dbt</strong>
              <p>Freelance instructor for dbt Labs, running live dbt Cloud training for data teams around the world.</p>
            </div>
          </div>
          <div class="now-card">
            <div class="now-card-icon">&#x1F3EB;</div>
            <div>
              <strong>Building Online Courses</strong>
              <p>Developing self-paced online courses on data engineering and hands-on SQL learning.</p>
            </div>
          </div>
          <div class="now-card">
            <div class="now-card-icon">&#x270D;&#xFE0F;</div>
            <div>
              <strong>Writing a Second Book</strong>
              <p><em>The Data Consultant's Handbook</em>, covering the business side of consulting that most technical content skips.</p>
            </div>
          </div>
          <div class="now-card">
            <div class="now-card-icon">&#x1F3A4;</div>
            <div>
              <strong>Speaking at Conferences</strong>
              <p>Regularly showing up and speaking at data meetups and conferences across the world.</p>
            </div>
          </div>
        </div>

        <!-- Section 2: Map + Places Lived -->
        <h2>Around the World</h2>
        <p>I've lived in four countries and spoken in many more.</p>

        <div class="map-section">
          <div class="map-col">
            <p class="map-col-label">Where I've Lived</p>
            <div class="countries-lived">
              {[
                { key: 'colombia' as const, name: 'Colombia', note: 'Born and Raised' },
                { key: 'uk' as const, name: 'United Kingdom', note: '1 year' },
                { key: 'netherlands' as const, name: 'Netherlands', note: '15 years' },
                { key: 'usa' as const, name: 'United States', note: 'Since 2026' },
              ].map(({ key, name, note }) => (
                <div class="country-item">
                  <svg
                    class="country-svg"
                    viewBox={`0 0 ${COUNTRY_W} ${COUNTRY_H}`}
                    preserveAspectRatio="xMidYMid meet"
                    role="img"
                    aria-label={`Map silhouette of ${name}`}
                  >
                    {countryPaths[key] && <path d={countryPaths[key]} fill="#2563eb" opacity="0.75" />}
                  </svg>
                  <div class="country-label">
                    <strong>{name}</strong>
                    <span>{note}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="map-col">
            <p class="map-col-label">Where I've Spoken</p>
            <div class="continent-maps">
              {continentPanels.map((panel) => (
                <div class="continent-panel">
                  <svg
                    class="continent-svg"
                    viewBox={`0 0 ${PANEL_W} ${PANEL_H}`}
                    preserveAspectRatio="xMidYMid meet"
                    role="img"
                    aria-label={`Map of ${panel.label} with talk locations: ${panel.dots.map(d => d.location).join(', ') || 'none'}`}
                  >
                    {panel.paths.map((d) => (
                      <path d={d} fill="#1a2d4a" stroke="#2d4a6f" stroke-width="0.5" />
                    ))}
                    {panel.dots.map((dot) => (
                      <circle
                        class="talk-dot"
                        cx={dot.x}
                        cy={dot.y}
                        r="3.5"
                        fill="#2563eb"
                        stroke="#60a5fa"
                        stroke-width="1.5"
                        tabindex="0"
                        role="button"
                        data-location={dot.location}
                        aria-label={`Talks in ${dot.location}`}
                      />
                    ))}
                  </svg>
                  <span class="continent-label">{panel.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Section 3: Experience Timeline -->
        <h2>Previous Experience</h2>
        <p style="font-size: 1.1rem; color: var(--color-text-light); margin-bottom: 2rem;">
          A decade of experience teaching, working with data, and building community around analytics engineering.
        </p>

        <ExperienceTimeline />


      </div>
    </div>
  </section>
</BaseLayout>

<!-- Talk-location tooltips. Maps themselves are rendered at build time. -->
<script is:inline define:vars={{ talksByLocation }}>
(function () {
  var tooltip = document.createElement('div');
  tooltip.id = 'talk-tooltip';
  document.body.appendChild(tooltip);

  // Build tooltip content with DOM APIs so titles/URLs are never parsed as HTML
  function buildTooltip(location) {
    tooltip.replaceChildren();
    var talks = talksByLocation[location] || [];
    if (!talks.length) return false;

    var heading = document.createElement('div');
    heading.className = 'talk-tooltip-heading';
    heading.textContent = location;
    tooltip.appendChild(heading);

    talks.forEach(function (t) {
      var item = document.createElement('div');
      item.className = 'talk-tooltip-item';

      var title;
      if (t.url) {
        title = document.createElement('a');
        title.href = t.url;
        title.target = '_blank';
        title.rel = 'noopener';
        title.className = 'talk-tooltip-link';
      } else {
        title = document.createElement('strong');
      }
      title.textContent = t.title;
      item.appendChild(title);

      var cleanEvent = t.event
        ? t.event.replace(new RegExp('\\b' + t.year + '\\b', 'g'), '').trim().replace(/[-–\s]+$/, '').trim()
        : '';
      var meta = document.createElement('div');
      meta.className = 'talk-tooltip-meta';
      meta.textContent = [cleanEvent, t.year].filter(Boolean).join(' · ');
      item.appendChild(meta);

      tooltip.appendChild(item);
    });
    return true;
  }

  function showTooltip(x, y, location) {
    if (!buildTooltip(location)) return;
    tooltip.classList.add('visible');
    moveTooltip(x, y);
  }

  function moveTooltip(clientX, clientY) {
    var x = clientX + 14, y = clientY - 10;
    if (x + 270 > window.innerWidth) x = clientX - 270;
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function hideTooltip() { tooltip.classList.remove('visible'); }

  document.querySelectorAll('.talk-dot').forEach(function (dot) {
    var location = dot.getAttribute('data-location');

    dot.addEventListener('mouseover', function (evt) { showTooltip(evt.clientX, evt.clientY, location); });
    dot.addEventListener('mousemove', function (evt) { moveTooltip(evt.clientX, evt.clientY); });
    dot.addEventListener('mouseout', hideTooltip);

    // Keyboard: show near the dot on focus, dismiss on blur/Escape
    dot.addEventListener('focus', function () {
      var rect = dot.getBoundingClientRect();
      showTooltip(rect.right, rect.top, location);
    });
    dot.addEventListener('blur', hideTooltip);
    dot.addEventListener('keydown', function (evt) {
      if (evt.key === 'Escape') hideTooltip();
    });

    // Touch: tap toggles the tooltip
    dot.addEventListener('click', function (evt) {
      if (tooltip.classList.contains('visible')) {
        hideTooltip();
      } else {
        showTooltip(evt.clientX, evt.clientY, location);
      }
    });
  });
})();
</script>

<style is:global>
  #talk-tooltip {
    position: fixed;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 1000;
    background: var(--color-bg-secondary, #1a2d4a);
    border: 1px solid var(--color-border, #2d4a6f);
    border-radius: 0.5rem;
    padding: 0.6rem 0.85rem;
    max-width: 260px;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-text, #e2e8f0);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  #talk-tooltip.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .talk-tooltip-heading {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.4rem;
  }

  .talk-tooltip-item {
    margin-bottom: 0.5rem;
  }

  .talk-tooltip-link {
    color: #60a5fa;
    text-decoration: none;
    font-weight: 600;
  }

  .talk-tooltip-meta {
    color: #94a3b8;
    font-size: 0.72rem;
    margin-top: 0.1rem;
  }

  .talk-dot {
    cursor: pointer;
  }

  .talk-dot:focus-visible {
    outline: 2px solid var(--color-accent, #f59e0b);
    outline-offset: 2px;
  }
</style>

<style>
/* ── Intro ── */
.about-intro {
  display: flex;
  gap: 3rem;
  align-items: flex-start;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}

.about-intro-text {
  flex: 1;
  min-width: 300px;
}

.about-intro-text h1 {
  margin-bottom: 1.5rem;
}

.about-intro-photo { flex-shrink: 0; }

.about-photo {
  width: 315px;
  height: 315px;
  border-radius: 50%;
  box-shadow: 0 0 0 4px var(--color-bg-secondary), 0 0 0 7px var(--color-border);
}

/* ── Now grid ── */
.now-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
  margin: 1.5rem 0 2.5rem;
}

.now-card {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1.25rem 1.5rem;
}

.now-card-icon {
  font-size: 1.5rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.1rem;
}

.now-card strong {
  display: block;
  margin-bottom: 0.4rem;
  font-size: 1rem;
}

.now-card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--color-text-light);
  line-height: 1.6;
}

/* ── Map section: lived left, spoken right ── */
.map-section {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1.25rem;
  align-items: stretch;
  margin: 1rem 0 2.5rem;
}

.map-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.map-col .countries-lived,
.map-col .continent-maps {
  flex: 1;
}

.map-col-label {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-text-light);
  margin: 0;
}

/* ── Country silhouettes ── */
.countries-lived {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  min-width: 0;
}

/* ── Continent talk panels ── */
.continent-maps {
  display: flex;
  gap: 0.75rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1rem;
  align-items: center;
}

.continent-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
}

.continent-svg {
  width: 100%;
  height: 200px;
  display: block;
}

.continent-label {
  font-size: 0.65rem;
  color: var(--color-text-light);
  text-align: center;
}

.country-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 0.6rem 0.4rem 0.5rem;
  min-width: 0;
}

.country-svg {
  width: 100%;
  height: 72px;
  display: block;
  overflow: hidden;
}

.country-label {
  text-align: center;
}

.country-label strong {
  display: block;
  font-size: 0.7rem;
  font-weight: 600;
  line-height: 1.3;
}

.country-label span {
  display: block;
  font-size: 0.65rem;
  color: var(--color-text-light);
  margin-top: 0.1rem;
}


/* ── Section padding override ── */
.content-section {
  padding-bottom: 2rem;
}


/* ── Responsive ── */
@media (max-width: 720px) {
  .map-section {
    grid-template-columns: 1fr;
  }

  #world-map {
    height: 220px;
  }

  .countries-lived {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (max-width: 480px) {
  .about-intro {
    flex-direction: column-reverse;
    align-items: center;
    text-align: center;
  }

  .about-intro-photo {
    display: flex;
    justify-content: center;
  }

  .countries-lived {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
