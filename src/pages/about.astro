<!-- Country silhouettes + continent talk panels via D3 + topojson -->
<script is:inline define:vars={{ talkMarkers: talkMarkersWithCount, talksByLocation }}>
(function () {
  // ── Tooltip ──
  var tooltip = document.createElement('div');
  tooltip.id = 'talk-tooltip';
  tooltip.style.cssText = 'position:fixed;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:1000;background:var(--color-bg-secondary,#1a2d4a);border:1px solid var(--color-border,#2d4a6f);border-radius:0.5rem;padding:0.6rem 0.85rem;max-width:260px;font-size:0.78rem;line-height:1.5;color:var(--color-text,#e2e8f0);box-shadow:0 4px 16px rgba(0,0,0,0.4);';
  document.body.appendChild(tooltip);

  function showTooltip(evt, location) {
    var talks = talksByLocation[location] || [];
    if (!talks.length) return;
    var html = talks.map(function(t) {
      var title = t.url
        ? '<a href="' + t.url + '" target="_blank" rel="noopener" style="color:#60a5fa;text-decoration:none;font-weight:600;">' + t.title + '</a>'
        : '<strong>' + t.title + '</strong>';
      var cleanEvent = t.event ? t.event.replace(new RegExp('\\b' + t.year + '\\b', 'g'), '').trim().replace(/[-–\s]+$/, '').trim() : '';
      var meta = [cleanEvent, t.year].filter(Boolean).join(' · ');
      return '<div style="margin-bottom:0.5rem;">' + title +
        '<div style="color:#94a3b8;font-size:0.72rem;margin-top:0.1rem;">' + meta + '</div>' +
        '</div>';
    }).join('');
    tooltip.innerHTML = '<div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#94a3b8;margin-bottom:0.4rem;">' + location + '</div>' + html;
    tooltip.style.opacity = '1';
    moveTooltip(evt);
  }

  function moveTooltip(evt) {
    var x = evt.clientX + 14, y = evt.clientY - 10;
    if (x + 270 > window.innerWidth) x = evt.clientX - 270;
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function hideTooltip() { tooltip.style.opacity = '0'; }

  // ── Country silhouettes (lived) ──
  var countries = [
    { id: 170, svgId: 'shape-col' },
    { id: 826, svgId: 'shape-gbr' },
    { id: 528, svgId: 'shape-nld' },
    { id: 840, svgId: 'shape-usa' },
  ];

  // ── Continent panels (spoken) ──
  var continentDefs = [
    { svgId: 'map-northamerica', bbox: [-125, 24, -66, 50] },
    { svgId: 'map-europe',       bbox: [-5,   35,  22, 57], includeIds: [250] },
    { svgId: 'map-southamerica', bbox: [-82, -56, -33, 14] },
  ];

  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src; s.onload = cb;
    document.head.appendChild(s);
  }

  var geoBounds = {
    528: [[3, 50], [8, 54]],
    826: [[-9, 49], [2, 58.8]],
    840: [[-130, 20], [-60, 55]],
    250: [[-5, 42], [8, 51]],
  };

  function filterToContinental(feature, bbox) {
    var geom = feature.geometry;
    function inBbox(ring) {
      var sx = 0, sy = 0;
      for (var i = 0; i < ring.length; i++) { sx += ring[i][0]; sy += ring[i][1]; }
      var cx = sx / ring.length, cy = sy / ring.length;
      return cx >= bbox[0][0] && cx <= bbox[1][0] && cy >= bbox[0][1] && cy <= bbox[1][1];
    }
    if (geom.type === 'Polygon') return inBbox(geom.coordinates[0]) ? feature : null;
    if (geom.type === 'MultiPolygon') {
      var polys = geom.coordinates.filter(function(p) { return inBbox(p[0]); });
      if (!polys.length) return null;
      return { type: 'Feature', geometry: { type: 'MultiPolygon', coordinates: polys } };
    }
    return feature;
  }

  loadScript('https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js', function () {
    loadScript('https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js', function () {
      fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-50m.json')
        .then(function (r) { return r.json(); })
        .then(function (world) {
          var allFeatures = topojson.feature(world, world.objects.countries).features;

          // ── Render country silhouettes ──
          var W = 100, H = 80, pad = 6;
          countries.forEach(function (c) {
            var feature = allFeatures.find(function (f) {
              return +f.id === c.id || f.id === String(c.id);
            });
            if (!feature) return;
            var svgEl = document.getElementById(c.svgId);
            if (!svgEl) return;
            var renderFeature = geoBounds[c.id] ? filterToContinental(feature, geoBounds[c.id]) : feature;
            if (!renderFeature) return;
            var projection = d3.geoMercator().fitExtent([[pad, pad], [W - pad, H - pad]], renderFeature);
            var pathGen = d3.geoPath().projection(projection);
            d3.select(svgEl)
              .attr('viewBox', '0 0 ' + W + ' ' + H)
              .attr('preserveAspectRatio', 'xMidYMid meet')
              .append('path')
              .attr('d', pathGen(renderFeature))
              .attr('fill', '#2563eb')
              .attr('opacity', '0.75');
          });

          // ── Render continent panels with talk dots ──
          var CW = 240, CH = 220, cpad = 8;
          continentDefs.forEach(function (cont) {
            var svgEl = document.getElementById(cont.svgId);
            if (!svgEl) return;

            var features = allFeatures.filter(function (f) {
              if (cont.includeIds && cont.includeIds.indexOf(+f.id) !== -1) return true;
              try {
                var c = d3.geoCentroid(f);
                return c[0] >= cont.bbox[0] && c[0] <= cont.bbox[2] &&
                       c[1] >= cont.bbox[1] && c[1] <= cont.bbox[3];
              } catch (e) { return false; }
            }).map(function (f) {
              var bounds = geoBounds[+f.id];
              return bounds ? filterToContinental(f, bounds) : f;
            }).filter(Boolean);

            if (!features.length) return;

            var collection = { type: 'FeatureCollection', features: features };
            var projection = d3.geoMercator()
              .fitExtent([[cpad, cpad], [CW - cpad, CH - cpad]], collection);
            var pathGen = d3.geoPath().projection(projection);

            var svg = d3.select(svgEl)
              .attr('viewBox', '0 0 ' + CW + ' ' + CH)
              .attr('preserveAspectRatio', 'xMidYMid meet');

            features.forEach(function (f) {
              svg.append('path')
                .attr('d', pathGen(f))
                .attr('fill', '#1a2d4a')
                .attr('stroke', '#2d4a6f')
                .attr('stroke-width', 0.5);
            });

            talkMarkers.forEach(function (m) {
              var lat = m.coords[0], lon = m.coords[1];
              if (lon < cont.bbox[0] || lon > cont.bbox[2] ||
                  lat < cont.bbox[1] || lat > cont.bbox[3]) return;
              var pt = projection([lon, lat]);
              if (!pt) return;
              svg.append('circle')
                .attr('cx', pt[0]).attr('cy', pt[1])
                .attr('r', 3.5)
                .attr('fill', '#2563eb')
                .attr('stroke', '#60a5fa')
                .attr('stroke-width', 1.5)
                .style('cursor', 'pointer')
                .on('mouseover', function(evt) { showTooltip(evt, m.location); })
                .on('mousemove', moveTooltip)
                .on('mouseout', hideTooltip);
            });
          });
        })
        .catch(function (err) {
          console.warn('Failed to load world map data:', err);
        });
    });
  });
})();
</script>

<style>
/* ── Intro ── */
.about-intro {
  display: flex;
  gap: 3rem;
  align-items: flex-start;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}

.about-intro-text {
  flex: 1;
  min-width: 300px;
}

.about-intro-text h1 {
  margin-bottom: 1.5rem;
}

.about-intro-photo { flex-shrink: 0; }

.about-photo {
  width: 315px;
  height: 315px;
  border-radius: 50%;
  box-shadow: 0 0 0 4px var(--color-bg-secondary), 0 0 0 7px var(--color-border);
}

/* ── Now grid ── */
.now-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
  margin: 1.5rem 0 2.5rem;
}

.now-card {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1.25rem 1.5rem;
}

.now-card-icon {
  font-size: 1.5rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.1rem;
}

.now-card strong {
  display: block;
  margin-bottom: 0.4rem;
  font-size: 1rem;
}

.now-card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--color-text-light);
  line-height: 1.6;
}

/* ── Map section: lived left, spoken right ── */
.map-section {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1.25rem;
  align-items: stretch;
  margin: 1rem 0 2.5rem;
}

.map-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.map-col .countries-lived,
.map-col .continent-maps {
  flex: 1;
}

.map-col-label {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-text-light);
  margin: 0;
}

/* ── Country silhouettes ── */
.countries-lived {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  min-width: 0;
}

/* ── Continent talk panels ── */
.continent-maps {
  display: flex;
  gap: 0.75rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1rem;
  align-items: center;
}

.continent-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
}

.continent-svg {
  width: 100%;
  height: 200px;
  display: block;
}

.continent-label {
  font-size: 0.65rem;
  color: var(--color-text-light);
  text-align: center;
}

.country-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 0.6rem 0.4rem 0.5rem;
  min-width: 0;
}

.country-svg {
  width: 100%;
  height: 72px;
  display: block;
  overflow: hidden;
}

.country-label {
  text-align: center;
}

