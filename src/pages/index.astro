---
import BaseLayout from '../layouts/BaseLayout.astro';
import YouTubeThumbnail from '../components/YouTubeThumbnail.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { formatDate, byDateDesc } from '../utils/format';
import profilePhoto from '../assets/profile_photo.webp';
import speakingImage from '../assets/services/speaking.jpg';
import trainingImage from '../assets/services/training.jpg';
import consultingImage from '../assets/services/consulting.jpg';

const recentBlogs = (await getCollection('blogs')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const recentVideos = (await getCollection('videos')).sort(byDateDesc).slice(0, 3);
const recentPodcasts = (await getCollection('guestAppearances')).sort(byDateDesc).slice(0, 3);
---

<BaseLayout title="juanalytics - Juan Manuel Perafan">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-max-width">
      <div class="hero-main">
        <Image
          src={profilePhoto}
          alt="Juan Manuel Perafan"
          class="hero-image"
          loading="eager"
          fetchpriority="high"
          width={400}
          height={400}
        />
        <p class="hero-eyebrow">Analytics Engineer · Instructor · Author · Community Builder</p>
        <h1 class="hero-title">Juan Manuel Perafan</h1>
        <p class="hero-description">
          A decade of experience helping organizations make their data resemble their business, not forcing their business to fit a data model. Welcome to my corner of the internet, where I keep my books, talks, videos, podcasts, and blogs.
        </p>
        <div class="specialty-tags">
          <span class="specialty-tag">Analytics Engineering</span>
          <span class="specialty-tag">dbt</span>
          <span class="specialty-tag">Data Modeling</span>
          <span class="specialty-tag">SQL</span>
          <span class="specialty-tag">Data Visualization</span>
          <span class="specialty-tag">Data Governance</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="section-with-bg">
    <div class="container">
      <h2 class="section-title">What You'll Find Here</h2>

      <div class="cards-grid">
        <a href="/talks" class="feature-card">
          <div class="feature-icon">
            <Icon name="presentation" size={24} />
          </div>
          <div class="feature-content">
            <h3>Conference Talks</h3>
            <p>Slides and recordings from live events</p>
          </div>
        </a>

        <a href="/videos" class="feature-card">
          <div class="feature-icon">
            <Icon name="play" size={24} />
          </div>
          <div class="feature-content">
            <h3>Video Tutorials</h3>
            <p>Technical deep dives and how-tos</p>
          </div>
        </a>

        <a href="/podcasts" class="feature-card">
          <div class="feature-icon">
            <Icon name="microphone" size={24} />
          </div>
          <div class="feature-content">
            <h3>Podcasts</h3>
            <p>Conversations about data and community</p>
          </div>
        </a>

        <a href="/blog" class="feature-card">
          <div class="feature-icon">
            <Icon name="document" size={24} />
          </div>
          <div class="feature-content">
            <h3>Blog Posts</h3>
            <p>Articles on analytics engineering</p>
          </div>
        </a>
      </div>

      <!-- Speaking & Training -->
      <div class="services-section">
        <h2 class="services-title">Let's Work Together</h2>
        <div class="services-grid">
          <div class="service-card">
            <Image
              src={speakingImage}
              alt="Speaking"
              class="service-image"
              loading="lazy"
              width={1200}
              height={674}
            />
            <div class="service-content">
              <h3 class="service-title">Speaking</h3>
              <p class="service-description">Looking for a speaker for your conference or meetup?</p>
            </div>
          </div>
          <div class="service-card">
            <Image
              src={trainingImage}
              alt="Training"
              class="service-image"
              loading="lazy"
              width={1200}
              height={674}
            />
            <div class="service-content">
              <h3 class="service-title">Training</h3>
              <p class="service-description">Want to train your team on data skills? I design and lead workshops.</p>
            </div>
          </div>
          <div class="service-card">
            <Image
              src={consultingImage}
              alt="Consulting"
              class="service-image"
              loading="lazy"
              width={1200}
              height={674}
            />
            <div class="service-content">
              <h3 class="service-title">Consulting</h3>
              <p class="service-description">Building a data strategy? I help organizations design data architectures.</p>
            </div>
          </div>
        </div>
        <div class="services-cta-container">
          <a href="/about" class="cta-button">
            Get in Touch
            <Icon name="arrow" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Podcasts (Guest Appearances) -->
  {recentPodcasts.length > 0 && (
    <section class="recent-section">
      <div class="container">
        <div class="section-header">
          <h2>Podcast Appearances</h2>
          <a href="/podcasts" class="view-all-link">View all →</a>
        </div>
        <div class="content-grid">
          {recentPodcasts.map((podcast) => (
            <a href={podcast.data.url} target="_blank" rel="noopener noreferrer" class="card media-card">
              {podcast.data.thumbnail ? (
                <img src={podcast.data.thumbnail} alt={podcast.data.title} class="media-image" />
              ) : (
                <div class="media-placeholder">
                  <Icon name="microphone" size={64} />
                </div>
              )}
              <div class="media-content">
                <h3 class="media-title">{podcast.data.title}</h3>
                <p class="media-meta">
                  {formatDate(podcast.data.date)}
                  {podcast.data.podcast && ` • ${podcast.data.podcast}`}
                  {podcast.data.episode && ` - Episode ${podcast.data.episode}`}
                </p>
                <p class="media-description">{podcast.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Recent Videos -->
  {recentVideos.length > 0 && (
    <section class="recent-section section-with-bg">
      <div class="container">
        <div class="section-header">
          <h2>Recent Videos</h2>
          <a href="/videos" class="view-all-link">View all →</a>
        </div>
        <div class="content-grid">
          {recentVideos.map((video) => (
            <a href={video.data.url} target="_blank" rel="noopener noreferrer" class="card media-card">
              <YouTubeThumbnail videoUrl={video.data.url} alt={video.data.title} thumbnail={video.data.thumbnail} />
              <div class="media-content">
                <h3 class="media-title">{video.data.title}</h3>
                <p class="media-meta">
                  {formatDate(video.data.date)}
                </p>
                <p class="media-description">{video.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Recent Blog Posts -->
  {recentBlogs.length > 0 && (
    <section class="recent-section">
      <div class="container">
        <div class="section-header">
          <h2>Recent Blog Posts</h2>
          <a href="/blog" class="view-all-link">View all →</a>
        </div>
        <div class="content-grid">
          {recentBlogs.map((post) => (
            <a href={`/blog/${post.id}`} class="card media-card">
              {post.data.heroImage ? (
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="media-image"
                  loading="lazy"
                />
              ) : (
                <div class="media-placeholder">
                  <p class="placeholder-text">Add heroImage in frontmatter</p>
                </div>
              )}
              <div class="media-content">
                <h3 class="media-title">{post.data.title}</h3>
                <p class="media-meta">
                  {formatDate(post.data.pubDate)}
                </p>
                <p class="media-description">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
