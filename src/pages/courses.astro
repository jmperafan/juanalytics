---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildUrl } from '../utils/urlHelper';

const fs = await import('fs');
const path = await import('path');
const yaml = await import('yaml');

const filePath = path.resolve(process.cwd(), './content/courses.yml');
const rawData = yaml.parse(fs.readFileSync(filePath, 'utf-8'));
const courses = rawData.courses || [];

const levelLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const uniqueLevels: string[] = Array.from(new Set(courses.map((c: any) => c.level).filter(Boolean)));
const uniqueTags: string[] = Array.from(new Set(courses.flatMap((c: any) => c.tags || []))).sort() as string[];
---

<BaseLayout
  title="Courses | juanalytics"
  description="Practical analytics engineering courses by Juan Manuel Perafan. Learn dbt, SQL, and data modeling with hands-on, real-world projects."
>
  <section class="courses-hero">
    <div class="container">
      <h1>Courses</h1>
      <p class="courses-hero-subtitle">
        Practical, no-fluff training for analytics engineers. Learn what actually matters in production.
      </p>
    </div>
  </section>

  <section class="courses-section">
    <div class="container">
      {courses.length === 0 ? (
        <p class="empty-state">No courses yet. Check back soon!</p>
      ) : (
        <div class="courses-with-sidebar">

          <!-- Filter Sidebar -->
          <aside class="courses-sidebar">
            <div class="sidebar-sticky">

              <div class="filter-group">
                <h3 class="filter-group-label">Level</h3>
                <div class="filter-buttons">
                  <button class="filter-btn active" data-filter-type="level" data-value="all">All Levels</button>
                  {uniqueLevels.map((level: string) => (
                    <button class="filter-btn" data-filter-type="level" data-value={level}>
                      {levelLabels[level] || level}
                    </button>
                  ))}
                </div>
              </div>

              {uniqueTags.length > 0 && (
                <div class="filter-group">
                  <h3 class="filter-group-label">Topic</h3>
                  <div class="filter-buttons">
                    <button class="filter-btn active" data-filter-type="topic" data-value="all">All Topics</button>
                    {uniqueTags.map((tag: string) => (
                      <button class="filter-btn" data-filter-type="topic" data-value={tag}>{tag}</button>
                    ))}
                  </div>
                </div>
              )}

            </div>
          </aside>

          <!-- Course Grid -->
          <div id="courses-grid" class="courses-grid">
            {courses.map((course: any) => (
              <div
                class="course-card"
                data-level={course.level || ''}
                data-tags={JSON.stringify(course.tags || [])}
              >
                <div class="course-thumbnail">
                  {course.thumbnail ? (
                    <img src={course.thumbnail} alt={course.en?.title || course.slug} />
                  ) : (
                    <div class="course-thumbnail-placeholder">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                        <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                      </svg>
                      <span>Course Thumbnail</span>
                    </div>
                  )}
                  {course.status === 'coming_soon' && (
                    <span class="status-badge">Coming Soon</span>
                  )}
                </div>

                <div class="course-card-body">
                  <div class="course-meta-row">
                    {course.level && (
                      <span class={`course-level level-${course.level}`}>
                        {levelLabels[course.level] || course.level}
                      </span>
                    )}
                    {(course.duration || course.lessons) && (
                      <span class="course-duration">
                        {[course.duration, course.lessons && `${course.lessons} lessons`].filter(Boolean).join(' · ')}
                      </span>
                    )}
                  </div>

                  <!-- Show EN title as primary, ES title as secondary -->
                  <h2 class="course-title">{course.en?.title || course.es?.title}</h2>
                  <p class="course-subtitle">{course.en?.subtitle || course.es?.subtitle}</p>

                  {course.highlights && course.highlights.length > 0 && (
                    <ul class="course-highlights">
                      {course.highlights.slice(0, 3).map((h: string) => (
                        <li>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                          {h}
                        </li>
                      ))}
                    </ul>
                  )}

                  <div class="course-footer">
                    <div class="course-price">
                      {course.originalPrice && (
                        <span class="price-original">${course.originalPrice}</span>
                      )}
                      <span class="price-current">${course.price}</span>
                    </div>

                    <!-- Language buttons -->
                    <div class="course-lang-buttons">
                      {course.en && (
                        <a
                          href={buildUrl(`courses/${course.slug}-en`)}
                          class="lang-btn"
                          title="English"
                        >🇺🇸 EN</a>
                      )}
                      {course.es && (
                        <a
                          href={buildUrl(`courses/${course.slug}-es`)}
                          class="lang-btn"
                          title="Español"
                        >🇪🇸 ES</a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    let activeLevel = 'all';
    let activeTopic = 'all';

    const cards = document.querySelectorAll('.course-card');

    function applyFilters() {
      cards.forEach(card => {
        const level = card.getAttribute('data-level') || '';
        const tags = JSON.parse(card.getAttribute('data-tags') || '[]');

        const levelMatch = activeLevel === 'all' || level === activeLevel;
        const topicMatch = activeTopic === 'all' || tags.includes(activeTopic);

        card.style.display = (levelMatch && topicMatch) ? 'flex' : 'none';
      });
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.getAttribute('data-filter-type');
        const value = btn.getAttribute('data-value') || 'all';

        document.querySelectorAll(`.filter-btn[data-filter-type="${type}"]`).forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        if (type === 'level') activeLevel = value;
        if (type === 'topic') activeTopic = value;

        applyFilters();
      });
    });
  });
</script>

<style>
  .courses-hero {
    padding: 4rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .courses-hero h1 { margin-bottom: 0.75rem; }

  .courses-hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 560px;
    margin: 0;
  }

  .courses-section { padding: 3rem 0 5rem; }

  .courses-with-sidebar {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  /* Sidebar */
  .courses-sidebar {
    flex-shrink: 0;
    width: 200px;
  }

  .sidebar-sticky {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .filter-group-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .filter-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .filter-btn {
    background: var(--color-bg-secondary);
    color: var(--color-text);
    padding: 0.45rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
  }

  .filter-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .filter-btn.active { background: var(--color-primary); color: white; border-color: var(--color-primary); }

  /* Course Grid */
  .courses-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .course-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .course-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.12);
  }

  .course-thumbnail {
    position: relative;
    width: 100%;
    height: 190px;
    background: var(--color-bg);
    overflow: hidden;
  }

  .course-thumbnail img { width: 100%; height: 100%; object-fit: cover; }

  .course-thumbnail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--color-text-light);
    background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-secondary) 100%);
    font-size: 0.875rem;
  }

  .status-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--color-accent);
    color: #0f172a;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .course-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .course-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .course-level {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .level-beginner    { background: rgba(16, 185, 129, 0.15); color: #10b981; }
  .level-intermediate { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .level-advanced    { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

  .course-duration { font-size: 0.8125rem; color: var(--color-text-light); }

  .course-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .course-subtitle {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  .course-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .course-highlights li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .course-highlights li svg { flex-shrink: 0; margin-top: 2px; color: var(--color-primary); }

  .course-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .course-price { display: flex; align-items: center; gap: 0.5rem; }

  .price-original {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    text-decoration: line-through;
  }

  .price-current { font-size: 1.375rem; font-weight: 700; color: var(--color-text); }

  /* Language buttons */
  .course-lang-buttons {
    display: flex;
    gap: 0.4rem;
  }

  .lang-btn {
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.3rem 0.625rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-light);
    text-decoration: none;
    transition: all 0.15s;
  }

  .lang-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(37, 99, 235, 0.08);
  }

  @media (max-width: 768px) {
    .courses-with-sidebar { flex-direction: column; }
    .courses-sidebar { width: 100%; }
    .sidebar-sticky { position: static; flex-direction: row; gap: 1.5rem; overflow-x: auto; }
    .filter-group { flex-shrink: 0; }
    .filter-buttons { flex-direction: row; flex-wrap: wrap; }
    .courses-grid { grid-template-columns: 1fr; }
  }
</style>
