---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateReadingTime, formatReadingTime } from '../../utils/readingTime';
import { formatDate } from '../../utils/format';
import logo from '../../assets/logo.webp';
import profilePhoto from '../../assets/profile_photo.webp';

export async function getStaticPaths() {
  const blogs = await getCollection('blogs');
  return blogs.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

// Calculate reading time
const readingTime = calculateReadingTime(post.body || '');

// Prepare structured data
const site = Astro.site ?? new URL('https://juanalytics.com');
const blogPostStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": new URL(post.data.heroImage ?? profilePhoto.src, site).href,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Juan Manuel Perafan",
    "url": site.href,
    "sameAs": [
      "https://www.linkedin.com/in/jmperafan/",
      "https://github.com/jmperafan",
      "https://www.youtube.com/@juanalytics"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Juanalytics",
    "logo": {
      "@type": "ImageObject",
      "url": new URL(logo.src, site).href
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(`blog/${post.id}`, site).href
  },
  "keywords": post.data.tags?.join(', ') || '',
  "articleSection": "Analytics Engineering",
  "wordCount": (post.body || '').split(/\s+/).length,
  "timeRequired": `PT${readingTime}M`
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  ogType="article"
  publishDate={post.data.pubDate.toISOString()}
>
  <!-- Blog Post Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostStructuredData)} slot="head" />

  <article class="blog-post">
    <div class="container blog-post-container">
      {post.data.heroImage && (
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="blog-post-hero"
          loading="eager"
          fetchpriority="high"
        />
      )}

      <h1 class="blog-post-title">{post.data.title}</h1>

      <div class="blog-post-meta">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>•</span>
        <span>{formatReadingTime(readingTime)}</span>
        {post.data.updatedDate && (
          <span>• Updated {formatDate(post.data.updatedDate)}</span>
        )}
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="blog-post-tags">
          {post.data.tags.map((tag) => (
            <span class="blog-post-tag">{tag}</span>
          ))}
        </div>
      )}

      <div class="blog-post-content">
        <Content />
      </div>

      <div class="blog-post-footer">
        <a href="/blog" class="blog-back-link">← Back to blog</a>
      </div>
    </div>
  </article>

  <script>
    // Make external links (non-YouTube) open in a new tab
    document.addEventListener('DOMContentLoaded', () => {
      const contentDiv = document.querySelector('.blog-post-content');
      if (contentDiv) {
        const links = contentDiv.querySelectorAll('a');
        links.forEach((link) => {
          const href = link.getAttribute('href');
          // Check if it's an external link (starts with http/https)
          if (href && (href.startsWith('http://') || href.startsWith('https://'))) {
            // Check if it's NOT a YouTube link (those are handled separately in video pages)
            if (!href.includes('youtube.com') && !href.includes('youtu.be')) {
              link.setAttribute('target', '_blank');
              link.setAttribute('rel', 'noopener noreferrer');
            }
          }
        });
      }
    });
  </script>
</BaseLayout>
