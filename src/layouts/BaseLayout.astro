---
import '../styles/global.css';
import '../styles/layout.css';
import '../styles/content.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo.webp';
import profilePhoto from '../assets/profile_photo.webp';

interface Props {
  title: string;
  description?: string;
  image?: string;
  author?: string;
  publishDate?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = "Portfolio of Juan Manuel Perafan - Analytics Engineer, dbt Community Award Recipient, and Data Community Organizer",
  image = profilePhoto.src,
  author = "Juan Manuel Perafan",
  publishDate,
  ogType = 'website'
} = Astro.props;

const site = Astro.site ?? new URL('https://juanalytics.com');
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const imageUrl = image.startsWith("http") ? image : new URL(image, site).href;

const personStructuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Juan Manuel Perafan",
  "url": site.href,
  "image": new URL(profilePhoto.src, site).href,
  "description": "Analytics Engineer, dbt Community Award Recipient, and Data Community Organizer",
  "jobTitle": "Analytics Engineer",
  "sameAs": [
    "https://www.linkedin.com/in/jmperafan/",
    "https://github.com/jmperafan",
    "https://www.youtube.com/@juanalytics",
    "https://linktr.ee/juanalytics"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Juanalytics"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content={author} />
    <link rel="icon" type="image/webp" href={logo.src} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Juanalytics Blog RSS Feed" href="/rss.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content="Juanalytics" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:creator" content="@juanalytics" />

    <!-- Article metadata -->
    {ogType === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}
    {ogType === 'article' && <meta property="article:author" content={author} />}

    <!-- Page-specific head content (structured data, etc.) -->
    <slot name="head" />
    
    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personStructuredData)} />
    
    <!-- Self-hosted font: preload to avoid FOUT -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>

    <!-- GoatCounter Analytics -->
    <script is:inline data-goatcounter="https://jmperafan.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <header>
      <nav class="site-nav container">
        <a href="/" class="logo-container">
          <Image
            src={logo}
            alt="Juanalytics Logo"
            class="logo-image"
            loading="eager"
            fetchpriority="high"
            width={200}
            height={200}
          />
        </a>
        <button
          class="mobile-menu-toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="nav-links"
          id="mobile-menu-toggle"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <div class="nav-links" id="nav-links">
          <a href="/talks">Conferences</a>
          <a href="/videos">Videos</a>
          <a href="/podcasts">Podcasts</a>
          <a href="/blog">Blog</a>
          <a href="/books">Books</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>

    <script>
      // Mobile menu functionality
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const navLinks = document.getElementById('nav-links');
      const body = document.body;

      function closeMobileMenu() {
        navLinks?.classList.remove('active');
        menuToggle?.setAttribute('aria-expanded', 'false');
        body.style.overflow = ''; // Re-enable scrolling
      }

      function openMobileMenu() {
        navLinks?.classList.add('active');
        menuToggle?.setAttribute('aria-expanded', 'true');
        body.style.overflow = 'hidden'; // Prevent body scroll when menu is open
      }

      // Toggle menu on button click
      menuToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (navLinks?.classList.contains('active')) {
          closeMobileMenu();
        } else {
          openMobileMenu();
        }
      });

      // Close menu when clicking a link
      navLinks?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMobileMenu();
        });
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (navLinks?.classList.contains('active') &&
            !navLinks.contains(e.target as Node) &&
            !menuToggle?.contains(e.target as Node)) {
          closeMobileMenu();
        }
      });

      // Close menu on ESC key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && navLinks?.classList.contains('active')) {
          closeMobileMenu();
          menuToggle?.focus(); // Return focus to toggle button
        }
      });

      // Prevent menu from staying open on resize to desktop
      let resizeTimer: number;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          if (window.innerWidth > 768) {
            closeMobileMenu();
          }
        }, 250);
      });
    </script>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-content">
        <div class="footer-brand">
          <span class="footer-name">Juan Manuel Perafan</span>
          <span class="footer-tagline">Analytics Engineer · Connecticut, US</span>
        </div>
        <div class="footer-links">
          <a href="https://www.linkedin.com/in/jmperafan/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/jmperafan" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://youtube.com/@juanalytics" target="_blank" rel="noopener noreferrer">YouTube</a>
          <a href="/rss.xml" title="Subscribe to RSS Feed" aria-label="Subscribe to RSS Feed">RSS</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
