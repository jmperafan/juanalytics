---
interface Props {
  src: string;
  alt: string;
  fit?: 'cover' | 'contain';
}

const { src, alt, fit } = Astro.props;
---

<div class="thumbnail-wrapper" style={`--thumb: url('${src}')`} data-fit={fit}>
  <img
    src={src}
    alt={alt}
    class="thumbnail-image"
    onload="
      const forced = this.parentElement.dataset.fit;
      const cls = forced ?? 'contain';
      this.parentElement.classList.add('fit-' + cls);
    "
  />
</div>

<style>
  .thumbnail-wrapper {
    width: 100%;
    height: 200px;
    position: relative;
    overflow: hidden;
  }

  .thumbnail-image {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* Wide & slightly-off: cover with center crop */
  .thumbnail-wrapper.fit-cover .thumbnail-image {
    object-fit: cover;
    object-position: center;
  }

  /* Square/portrait (Spotify-style): contain + blurred backdrop */
  .thumbnail-wrapper.fit-contain::before {
    content: '';
    position: absolute;
    inset: -10px;
    background-image: var(--thumb);
    background-size: cover;
    background-position: center;
    filter: blur(14px);
  }

  .thumbnail-wrapper.fit-contain .thumbnail-image {
    object-fit: contain;
  }
</style>
