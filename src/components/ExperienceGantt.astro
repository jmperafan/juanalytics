---
import { experiences } from '../data/experience';

interface Props {
  width?: number;
}

const { width = 900 } = Astro.props;

// Filter only 'role' type items (ongoing positions)
const roleExperiences = experiences.filter(e => e.type !== 'highlight');

// Constants
const minYear = 2014;
const maxYear = 2027;
const yearRange = maxYear - minYear;
const margin = { top: 20, right: 60, bottom: 50, left: 220 };
const barHeight = 14;
const barSpacing = 4; // Space between bars in same group
const rowHeight = 36;
const categoryGap = 45;

// Group by category, then by organization for related items
interface DisplayRow {
  label: string;
  org: string;
  items: typeof roleExperiences;
}

const categories = Array.from(new Set(roleExperiences.map(e => e.category)));
const categoryData = categories.map(cat => {
  const catItems = roleExperiences.filter(e => e.category === cat);
  const rows: DisplayRow[] = [];

  // Group by organization for teaching roles, otherwise individual
  const grouped: Record<string, typeof catItems> = {};

  catItems.forEach(item => {
    const groupKey = item.category === 'Teaching' && item.org === 'University of Groningen'
      ? 'university-groningen'
      : item.id;

    if (!grouped[groupKey]) grouped[groupKey] = [];
    grouped[groupKey].push(item);
  });

  // Create display rows
  Object.entries(grouped).forEach(([key, items]) => {
    rows.push({
      label: items.length > 1 ? items[0].org : items[0].role,
      org: items[0].org,
      items,
    });
  });

  return { name: cat, rows };
});

// Calculate total height needed
let totalRows = 0;
categoryData.forEach((cat, idx) => {
  if (idx > 0) totalRows += 1.1;
  totalRows += 1; // Category header
  totalRows += cat.rows.length;
});

const plotHeight = totalRows * rowHeight;
const height = plotHeight + margin.top + margin.bottom;
const plotWidth = width - margin.left - margin.right;

// Helper to convert year+month to pixel position
const getXPosition = (year: number, month: number = 1) => {
  const totalMonths = (year - minYear) * 12 + (month - 1);
  return margin.left + (totalMonths / (yearRange * 12)) * plotWidth;
};

// Build row layout
let rowIndex = 0;
const rowMap: Record<string, { categoryRow: number; displayRowIndices: number[] }> = {};

categoryData.forEach((cat, catIdx) => {
  if (catIdx > 0) rowIndex += 1.1;
  const categoryRow = rowIndex;
  const displayRowIndices: number[] = [];
  rowIndex += 1;

  cat.rows.forEach(() => {
    displayRowIndices.push(rowIndex);
    rowIndex += 1;
  });

  rowMap[cat.name] = { categoryRow, displayRowIndices };
});
---

<div class="gantt-container">
  <svg
    {width}
    {height}
    viewBox={`0 0 ${width} ${height}`}
    preserveAspectRatio="xMidYMid meet"
    class="gantt-svg"
  >
    <!-- Background -->
    <rect width={width} height={height} fill="transparent" />

    <!-- Year grid lines (very subtle) -->
    {
      Array.from({ length: yearRange + 1 }).map((_, i) => {
        if (i > 0) {
          const x = margin.left + (i / yearRange) * plotWidth;
          return (
            <line
              x1={x}
              y1={margin.top}
              x2={x}
              y2={height - margin.bottom}
              stroke="var(--color-border)"
              stroke-width="0.5"
              opacity="0.08"
            />
          );
        }
      })
    }

    <!-- Categories and rows -->
    {
      categoryData.map((cat) => {
        const catRowData = rowMap[cat.name];
        const categoryY = margin.top + catRowData.categoryRow * rowHeight;

        return (
          <>
            <!-- Category header -->
            <text
              x={margin.left - 15}
              y={categoryY + rowHeight * 0.5 + 4}
              text-anchor="end"
              font-size="11"
              font-weight="700"
              fill="var(--color-text-light)"
              text-transform="uppercase"
              letter-spacing="0.08em"
            >
              {cat.name}
            </text>

            <!-- Display rows -->
            {
              cat.rows.map((displayRow, displayRowIdx) => {
                const displayRowIndex = catRowData.displayRowIndices[displayRowIdx];
                const baseY = margin.top + displayRowIndex * rowHeight + rowHeight * 0.5;

                return (
                  <g class="row-group">
                    <!-- Row label -->
                    {displayRow.items.length > 1 ? (
                      <>
                        <text
                          x={margin.left - 15}
                          y={baseY - 2}
                          text-anchor="end"
                          font-size="9"
                          font-weight="600"
                          fill="var(--color-text-light)"
                          class="row-label"
                        >
                          {displayRow.org}
                        </text>
                      </>
                    ) : (
                      <>
                        <text
                          x={margin.left - 15}
                          y={baseY + 4}
                          text-anchor="end"
                          font-size="10"
                          font-weight="600"
                          fill="var(--color-text)"
                          class="row-label"
                        >
                          {displayRow.label}
                        </text>
                        <text
                          x={margin.left - 15}
                          y={baseY + 13}
                          text-anchor="end"
                          font-size="8"
                          fill="var(--color-text-light)"
                          class="row-org"
                        >
                          {displayRow.org}
                        </text>
                      </>
                    )}

                    <!-- Bars for items in this row -->
                    {
                      displayRow.items.map((item, itemIdx) => {
                        const startX = getXPosition(item.startYear, item.startMonth);
                        const endMonthNum = (item.endYear - minYear) * 12 + (item.endMonth || 12);
                        const endX =
                          margin.left +
                          (endMonthNum / (yearRange * 12)) * plotWidth;
                        const barW = Math.max(endX - startX, 3);

                        // Offset bars vertically if multiple in same row
                        const barOffset =
                          displayRow.items.length > 1
                            ? itemIdx * (barHeight + barSpacing) - (barHeight + barSpacing) * 0.5
                            : 0;

                        return (
                          <g class="bar-item">
                            <rect
                              x={startX}
                              y={baseY + barOffset - barHeight / 2}
                              width={barW}
                              height={barHeight}
                              fill="var(--color-primary)"
                              rx="2"
                              opacity="0.85"
                              class="gantt-bar"
                            />
                            {barW > 50 && (
                              <text
                                x={startX + barW / 2}
                                y={baseY + barOffset + 3}
                                text-anchor="middle"
                                font-size="8"
                                font-weight="500"
                                fill="white"
                                pointer-events="none"
                                opacity="0.9"
                              >
                                {item.startYear === item.endYear
                                  ? item.startYear
                                  : `${item.startYear}–${item.endYear}`}
                              </text>
                            )}
                            <title>{`${item.role}\n${item.org}\n${item.startYear}${item.startMonth ? '/' + item.startMonth : ''} – ${item.endYear}${item.endMonth ? '/' + item.endMonth : ''}`}</title>
                          </g>
                        );
                      })
                    }
                  </g>
                );
              })
            }
          </>
        );
      })
    }

    <!-- Year labels -->
    {
      Array.from({ length: yearRange + 1 }).map((_, i) => {
        if (i % 2 === 0) {
          const year = minYear + i;
          const x = margin.left + (i / yearRange) * plotWidth;
          return (
            <text
              x={x}
              y={height - 28}
              text-anchor="middle"
              font-size="11"
              font-weight="500"
              fill="var(--color-text)"
            >
              {year}
            </text>
          );
        }
      })
    }

    <!-- Quarter markers -->
    {
      Array.from({ length: yearRange * 4 + 1 }).map((_, i) => {
        if (i > 0) {
          const x = margin.left + (i / (yearRange * 4)) * plotWidth;
          return (
            <line
              x1={x}
              y1={height - 48}
              x2={x}
              y2={height - 44}
              stroke="var(--color-border)"
              stroke-width="0.5"
              opacity="0.2"
            />
          );
        }
      })
    }
  </svg>
</div>

<style>
  .gantt-container {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem 2rem 2.5rem 1rem;
    overflow-x: auto;
    margin-bottom: 2rem;
    transition: box-shadow 0.2s;
  }

  .gantt-container:hover {
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.08);
  }

  .gantt-svg {
    width: 100%;
    height: auto;
    min-width: 500px;
  }

  .gantt-bar {
    transition: opacity 0.2s, filter 0.2s;
    cursor: pointer;
  }

  .gantt-bar:hover {
    opacity: 1 !important;
    filter: brightness(1.15);
  }

  .row-label {
    font-weight: 600;
  }

  .row-org {
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .gantt-container {
      padding: 1rem;
    }
  }
</style>
