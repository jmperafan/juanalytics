---
import { getCollection } from 'astro:content';

interface Role {
  role: string;
  org: string;
  startYear: number;
  startMonth: number;
  endYear: number | null;
  endMonth: number | null;
  description: string;
}

const entries = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order
);

const parseYearMonth = (value: string | null): [number | null, number | null] => {
  if (!value) return [null, null];
  const [year, month] = value.split('-').map(Number);
  return [year, month];
};

const roles: Array<Role & { group?: string; id: string }> = entries.map((entry) => {
  const [startYear, startMonth] = parseYearMonth(entry.data.start);
  const [endYear, endMonth] = parseYearMonth(entry.data.end);
  return {
    id: entry.id,
    role: entry.data.role,
    org: entry.data.org,
    group: entry.data.group,
    startYear: startYear!,
    startMonth: startMonth!,
    endYear,
    endMonth,
    description: entry.data.description,
  };
});

// Rows render in file order; entries sharing a `group` share one row.
const rows: Role[][] = [];
const rowByGroup = new Map<string, Role[]>();
for (const role of roles) {
  const key = role.group;
  if (key && rowByGroup.has(key)) {
    rowByGroup.get(key)!.push(role);
    continue;
  }
  const row = [role];
  if (key) rowByGroup.set(key, row);
  rows.push(row);
}

const minYear = 2014;
const maxYear = 2027;
const yearRange = maxYear - minYear;
const totalMonths = yearRange * 12;

// Dynamic current date for calculating durations
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;

// Helper to wrap text into multiple lines
const wrapText = (text: string, maxCharsPerLine: number = 56) => {
  const words = text.split(' ');
  const lines: string[] = [];
  let currentLine = '';

  words.forEach(word => {
    if ((currentLine + word).length <= maxCharsPerLine) {
      currentLine += (currentLine ? ' ' : '') + word;
    } else {
      if (currentLine) lines.push(currentLine);
      currentLine = word;
    }
  });
  if (currentLine) lines.push(currentLine);
  return lines;
};

const width = 1200;
const margin = { top: 40, right: 100, bottom: 80, left: 220 };
const barHeight = 32;
const rowHeight = 75;
const plotWidth = width - margin.left - margin.right;
const plotHeight = rows.length * rowHeight;
const svgHeight = plotHeight + margin.top + margin.bottom;

const getBarPosition = (role: Role) => {
  const startMonthNum = (role.startYear - minYear) * 12 + role.startMonth;
  const endMonthNum = role.endYear
    ? (role.endYear - minYear) * 12 + (role.endMonth || 12)
    : totalMonths;

  // Reverse X axis: newer dates on left, older on right
  const startX = margin.left + ((totalMonths - endMonthNum) / totalMonths) * plotWidth;
  const barWidth = Math.max(((endMonthNum - startMonthNum) / totalMonths) * plotWidth, 6);

  return { startX, barWidth };
};

const formatPeriod = (role: Role) =>
  `${role.startYear}-${String(role.startMonth).padStart(2, '0')} to ${
    role.endYear ? `${role.endYear}-${String(role.endMonth || 12).padStart(2, '0')}` : 'Present'
  }`;

const durationMonths = (role: Role) =>
  role.endYear
    ? (role.endYear - role.startYear) * 12 + (role.endMonth || 12) - role.startMonth + 1
    : (currentYear - role.startYear) * 12 + currentMonth - role.startMonth + 1;
---

<div class="timeline-container timeline-desktop">
  <svg
    {width}
    height={svgHeight}
    viewBox={`0 0 ${width} ${svgHeight}`}
    preserveAspectRatio="xMidYMid meet"
    class="timeline-svg"
    role="img"
    aria-label={`Career timeline from ${minYear} to today: ${roles
      .map((r) => `${r.role} at ${r.org}, ${formatPeriod(r)}`)
      .join('; ')}`}
  >
    <!-- Year grid lines (reversed) -->
    {
      Array.from({ length: yearRange + 1 }).map((_, i) => {
        const x = margin.left + ((yearRange - i) / yearRange) * plotWidth;
        return (
          <line
            x1={x}
            y1={margin.top}
            x2={x}
            y2={svgHeight - margin.bottom}
            stroke="var(--color-border)"
            stroke-width="0.5"
            opacity="0.05"
          />
        );
      })
    }

    <!-- One row per role (or group of related roles) -->
    {
      rows.map((row, rowIdx) => {
        const y = margin.top + rowIdx * rowHeight + rowHeight / 2;

        return row.map((role, barIdx) => {
          const { startX, barWidth } = getBarPosition(role);
          const tooltipX = Math.max(startX - 10, margin.left);
          const tooltipWidth = 360;
          const tooltipCenterX = tooltipX + tooltipWidth / 2;
          const descriptionLines = wrapText(role.description);
          const tooltipHeight = 93 + descriptionLines.length * 16;

          return (
            <g class="role-item" tabindex="0" aria-label={`${role.role} at ${role.org}, ${formatPeriod(role)}`}>
              <!-- Bar -->
              <rect
                x={startX}
                y={y - barHeight / 2}
                width={barWidth}
                height={barHeight}
                fill="var(--color-primary)"
                rx="4"
                opacity="0.8"
                class="bar"
              />

              <!-- Role + org labels (left of the row, once per row) -->
              {barIdx === 0 && (
                <text
                  x={margin.left - 20}
                  y={y - 6}
                  text-anchor="end"
                  font-size="13"
                  font-weight="600"
                  fill="var(--color-text)"
                >
                  {role.role}
                </text>
              )}
              {barIdx === 0 && (
                <text
                  x={margin.left - 20}
                  y={y + 10}
                  text-anchor="end"
                  font-size="11"
                  font-weight="400"
                  fill="var(--color-text-light)"
                >
                  {role.org}
                </text>
              )}

              <!-- Duration in months (right of bar) -->
              <text
                x={startX + barWidth + 6}
                y={y + 4}
                text-anchor="start"
                font-size="11"
                font-weight="500"
                fill="var(--color-text-light)"
              >
                {durationMonths(role)} m
              </text>

              <!-- Hover/focus tooltip -->
              <g class="tooltip-group" opacity="0">
                <rect
                  x={tooltipX}
                  y={y - tooltipHeight - 10}
                  width={tooltipWidth}
                  height={tooltipHeight}
                  fill="var(--color-bg-primary)"
                  stroke="var(--color-border)"
                  stroke-width="1"
                  rx="4"
                />
                <text
                  x={tooltipCenterX}
                  y={y - tooltipHeight + 18}
                  text-anchor="middle"
                  font-size="15"
                  font-weight="700"
                  fill="var(--color-text)"
                >
                  {role.role}
                </text>
                <text
                  x={tooltipCenterX}
                  y={y - tooltipHeight + 36}
                  text-anchor="middle"
                  font-size="12"
                  font-weight="500"
                  fill="var(--color-text-light)"
                  opacity="0.9"
                >
                  {role.org}
                </text>
                <text
                  x={tooltipCenterX}
                  y={y - tooltipHeight + 53}
                  text-anchor="middle"
                  font-size="11"
                  font-weight="400"
                  fill="var(--color-text-light)"
                  opacity="0.75"
                >
                  {formatPeriod(role)}
                </text>
                {descriptionLines.map((line, idx) => (
                  <text
                    x={tooltipX + 25}
                    y={y - tooltipHeight + 82 + idx * 16}
                    text-anchor="start"
                    font-size="11"
                    fill="var(--color-text-light)"
                  >
                    {line}
                  </text>
                ))}
              </g>

              <title>{`${role.role} • ${role.org}\n${formatPeriod(role)}\n${role.description}`}</title>
            </g>
          );
        });
      })
    }

    <!-- Year labels (reversed) -->
    {
      Array.from({ length: yearRange + 1 }).map((_, i) => {
        if (i % 2 === 0) {
          const year = minYear + i;
          const x = margin.left + ((yearRange - i) / yearRange) * plotWidth;
          return (
            <text
              x={x}
              y={svgHeight - 20}
              text-anchor="middle"
              font-size="12"
              font-weight="500"
              fill="var(--color-text-light)"
            >
              {year}
            </text>
          );
        }
      })
    }
  </svg>
</div>

<!-- Mobile: vertical list instead of the gantt chart -->
<ol class="timeline-mobile">
  {roles.map((role) => (
    <li class="timeline-mobile-item">
      <div class="timeline-mobile-header">
        <span class="timeline-mobile-role">{role.role}</span>
        <span class="timeline-mobile-duration">{durationMonths(role)} mo</span>
      </div>
      <span class="timeline-mobile-org">{role.org}</span>
      <span class="timeline-mobile-period">{formatPeriod(role)}</span>
      <p class="timeline-mobile-description">{role.description}</p>
    </li>
  ))}
</ol>

<style>
  .timeline-container {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  .timeline-svg {
    width: 100%;
    height: auto;
    min-width: 600px;
  }

  .bar {
    transition: opacity 0.2s, filter 0.2s;
    cursor: pointer;
  }

  .role-item:hover .bar,
  .role-item:focus .bar {
    opacity: 1 !important;
    filter: brightness(1.15);
  }

  .role-item:hover,
  .role-item:focus {
    filter: drop-shadow(0 4px 12px rgba(37, 99, 235, 0.15));
    outline: none;
  }

  .role-item:hover .tooltip-group,
  .role-item:focus .tooltip-group {
    opacity: 1;
    animation: tooltipFadeIn 0.2s ease-out;
  }

  @keyframes tooltipFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .timeline-mobile {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    border-left: 2px solid var(--color-border);
  }

  .timeline-mobile-item {
    position: relative;
    padding: 0 0 1.75rem 1.25rem;
  }

  .timeline-mobile-item::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 0.35rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .timeline-mobile-item:last-child {
    padding-bottom: 0;
  }

  .timeline-mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
  }

  .timeline-mobile-role {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .timeline-mobile-duration {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-light);
  }

  .timeline-mobile-org {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-light);
    margin-top: 0.125rem;
  }

  .timeline-mobile-period {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-light);
    opacity: 0.75;
    margin-top: 0.125rem;
  }

  .timeline-mobile-description {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-light);
    margin: 0.5rem 0 0;
  }

  @media (max-width: 768px) {
    .timeline-desktop {
      display: none;
    }

    .timeline-mobile {
      display: block;
    }
  }
</style>
